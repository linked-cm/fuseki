{
  "name": "@_linked/fuseki",
  "description": "",
  "author": {
    "name": "",
    "email": "",
    "url": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "version": "2.0.3",
  "linkedPackage": true,
  "type": "module",
  "main": "lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "license": "ISC",
  "scripts": {
    "start": "npm exec linked dev",
    "build": "rimraf ./lib && yarn build-esm && yarn copy-to-lib",
    "build-esm": "echo \"compiling ESM\" && rimraf ./lib/esm && yarn tsc -p tsconfig-esm.json",
    "copy-to-lib": "echo 'copying CSS + JSON assets to lib folder' && yarn copyfiles -u 1 'src/**/*.css' 'src/**/*.json' lib/esm",
    "test": "echo 'no tests yet'",
    "test-debug": "env-cmd -e development yarn jest --passWithNoTests"
  },
  "keywords": [
    "lincd",
    "linked data",
    "interoperable",
    "semantic web",
    "web3"
  ],
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/esm/index.js"
    },
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "development": "./src/*.ts",
      "import": "./lib/esm/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "development": "./src/*.ts",
      "import": "./lib/esm/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "dependencies": {
    "@_linked/core": "*"
  },
  "devDependencies": {
    "@_linked/cli": "^1.2",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@jest/globals": "^29.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.14",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "copyfiles": "^2.4.1",
    "cross-fetch": "^4.1.0",
    "env-cmd": "^10.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.2",
    "typescript-plugin-css-modules": "^5.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
