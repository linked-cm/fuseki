    "@types/node": "^22.13.14",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "cross-fetch": "^4.1.0",
    "env-cmd": "^10.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.2",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript-plugin-css-modules": "^5.1.0"
