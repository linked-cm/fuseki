  "version": "1.0.2",
  "linkedPackage": true,
  "main": "lib/index.js",
  "types": "dist/lincd-fuseki.d.ts",
  "license": "ISC",
  "scripts": {
    "start": "npm exec linked dev",
    "build": "npm exec linked build",
    "prepublishOnly": "npm exec linked build production",
    "postpublish": "npm exec linked register",
    "test": "NODE_OPTIONS='' env-cmd -e development yarn jest",
    "test-debug": "env-cmd -e development yarn jest"
  },
  "keywords": [
    "lincd",
    "linked data",
    "interoperable",
    "semantic web",
    "web3"
  ],
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "dependencies": {
    "@_linked/core": "*"
  },
  "devDependencies": {
